<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tribunal.controller.MenuController">

    <left>
        <VBox spacing="16" style="-fx-background-color: #2c3e50;"
              prefWidth="220" alignment="TOP_LEFT">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="TRIBUNAL"
                   style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Button text="Procese" onAction="#openProcese"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

            <Button text="Ședințe" onAction="#openSedinteToate"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 15px;"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 15px; -fx-background-radius: 10px;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
