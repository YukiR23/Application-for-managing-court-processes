<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.tribunal.controller.ProcesController">

    <top>
        <HBox spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <TextField fx:id="txtSearch"
                       promptText="Număr dosar / Materie juridică / Stadiu"
                       prefWidth="300"/>
            <Button text="Caută" onAction="#handleSearch"/>
            <Button text="Refresh" onAction="#handleRefresh"/>

            <Button text="Vezi detalii proces" onAction="#handleDetaliiProces"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="8">
        <TableView fx:id="tableProcese">

            <columns>
                <TableColumn fx:id="colNrDosar"
                             text="Nr Dosar"
                             prefWidth="140"/>

                <TableColumn fx:id="colMaterie"
                             text="Materie juridică"
                             prefWidth="220"/>

                <TableColumn fx:id="colStadiu"
                             text="Stadiu"
                             prefWidth="140"/>

                <TableColumn fx:id="colData"
                             text="Data înregistrare"
                             prefWidth="160"/>
            </columns>

        </TableView>
        </VBox>

    </center>

    <bottom>
        <VBox spacing="6">

            <HBox spacing="10">
                <padding>
                    <Insets top="10" right="10" bottom="0" left="10"/>
                </padding>

                <Button fx:id="btnAdd" text="Adaugă" onAction="#handleAdd"/>
                <Button fx:id="btnEdit" text="Editează" onAction="#handleEdit"/>
                <Button fx:id="btnDelete" text="Șterge" onAction="#handleDelete"/>
            </HBox>

            <HBox fx:id="undoBar"
                  spacing="10"
                  visible="false"
                  managed="false"
                  style="-fx-background-color: #fff3cd;
                     -fx-border-color: #ffeeba;
                     -fx-padding: 8;">

                <Label fx:id="lblUndo"
                       text="Proces șters"
                       style="-fx-text-fill: #856404;"/>

                <Button text="UNDO"
                        onAction="#undoDelete"/>
            </HBox>

        </VBox>
    </bottom>


</BorderPane>
